# Dapatkan dari @BotFather di Telegram
TELEGRAM_BOT_TOKEN=123456789:AAExampleTokenReplaceMe
# ID grup Telegram tujuan (angka negatif untuk grup, tambahkan bot ke grup lalu ambil chat_id via @userinfobot atau getUpdates)
TELEGRAM_CHAT_ID=-1001234567890
# Opsional: isi kalau grup pakai mode Topics dan mau kirim ke topic tertentu (bukan General).
# Cara ambil: buka topic tujuan di Telegram Desktop -> klik kanan/titik tiga -> "Copy Link",
# hasilnya https://t.me/c/xxxxxxxxxx/<message_thread_id> -- angka terakhir itu yang dipakai.
TELEGRAM_MESSAGE_THREAD_ID=

# Opsional, override default rule threshold
IDX_NEAR_PCT=3
IDX_FAR_PCT=15
IDX_MIN_TURNOVER=1000000000
IDX_FETCH_LIMIT=2000

# Opsional: kalau kosong, section "AI TOP PICKS" otomatis di-skip
MINIMAX_API_KEY=
MINIMAX_MODEL=MiniMax-M2
MINIMAX_BASE_URL=https://api.minimax.io/v1
